{
  "name": "projet_site_web_ing1",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "preview": "opennextjs-cloudflare build --config ../wrangler/wrangler.jsonc && opennextjs-cloudflare preview --config ../wrangler/wrangler.jsonc",
    "deploy": "opennextjs-cloudflare build --config ../wrangler/wrangler.jsonc && opennextjs-cloudflare deploy --config ../wrangler/wrangler.jsonc",
    "upload": "opennextjs-cloudflare build --config ../wrangler/wrangler.jsonc && opennextjs-cloudflare upload --config ../wrangler/wrangler.jsonc",
    "cf-typegen": "wrangler types --config ../wrangler/wrangler.jsonc --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/pdfkit": "^0.17.5",
    "next": "^16.2.2",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "typescript": "5.5.4",
    "wrangler": "^4.80.0"
  }
}
